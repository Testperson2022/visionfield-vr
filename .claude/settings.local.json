      "Bash(export PATH=\"$HOME/.dotnet:$PATH\")",
      "Bash(dotnet build:*)",
      "Bash(npm install:*)",
      "Bash(npx prisma:*)",
      "Bash(npx tsc:*)",
      "Bash(npx jest:*)",
      "Bash(npx vitest:*)",
      "Bash(npx vite:*)",
