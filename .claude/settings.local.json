{
  "permissions": {
    "allow": [
      "Bash(dotnet --version)",
      "Bash(winget list:*)",
      "Read(//c/Program Files/dotnet/**)",
      "Read(//c/Program Files \\(x86\\)/dotnet/**)",
      "Bash(curl -sL https://dot.net/v1/dotnet-install.sh -o /tmp/dotnet-install.sh)",
