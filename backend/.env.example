# VisionField VR — Backend Miljøvariabler
# Kopier til .env.local og udfyld med rigtige værdier.
# Gem ALDRIG .env.local i git — det er i .gitignore.

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://visionfield:PASSWORD@localhost:5432/visionfield_dev"

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="SKIFT-DETTE-TIL-MINDST-64-RANDOM-TEGN"
JWT_EXPIRES_IN="8h"
BCRYPT_COST=12

# ─── Kryptering (AES-256-GCM til patientdata) ─────────────────────────────────
# Generer med: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="SKIFT-DETTE-TIL-64-HEX-TEGN-32-BYTES"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS="http://localhost:5173"

# ─── Azure / Cloud Storage (produktion) ──────────────────────────────────────
# AZURE_STORAGE_CONNECTION_STRING=""
# AZURE_KEYVAULT_URL=""

# ─── Email (notifikationer til klinikere) ────────────────────────────────────
# SMTP_HOST=""
# SMTP_PORT=587
# SMTP_USER=""
# SMTP_PASSWORD=""
# SMTP_FROM="noreply@visionfield.dk"
